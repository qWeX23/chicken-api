# Copy this file to .env (or pass with --env-file) before `docker compose up`.

# Required: host path to your Google service account JSON credentials.
GOOGLE_APPLICATION_CREDENTIALS_FILE=/absolute/path/to/chicken-api-credentials.json

# Required: API key used for direct calls to Ollama's hosted API.
KOOG_OLLAMA_API_KEY=replace-with-real-key

# Optional: host port mapped to container port 8080.
CHICKEN_API_PORT=8080

# Optional: base URL for the Ollama instance on the shared Docker network.
# If your Ollama container/service name on the shared network is not `ollama`, update this.
KOOG_OLLAMA_BASE_URL=http://ollama:11434

# Optional: hosted Ollama web tools base URL used for web_search and web_fetch.
KOOG_OLLAMA_WEB_TOOLS_BASE_URL=https://ollama.com
